{
  "stories": [
    {
      "pid": "V14-P003",
      "volume_title": "卷十四·诺皋记上",
      "narrative_category": "异闻志怪",
      "title": "帝江·刑天舞干戚",
      "brief": "天山有神名浑水敦，六足重翼无面目，实为帝江。刑天与帝争神，被断首葬于常羊山，乃以乳为目、脐为口，操干戚而舞。",
      "monster_type": "神话异兽",
      "original_text": "天山有神，是为浑水敦。状如橐而光，其光如火。六足重翼，无面目。是识（一曰「嗜音」）歌舞，实为帝江。刑天与帝争神，帝断其首，葬之常羊山，乃以乱为目，脐为口，操干戚而舞焉。",
      "themes": [
        {
          "broad_category": "丧葬冥界",
          "level1_subject": "葬",
          "level2_subject": "葬",
          "specific_subject": "葬"
        }
      ],
      "shengui_keywords": [
        "神"
      ],
      "keyword_count": 1,
      "translation": "天山有一位神，名叫浑水敖。它的形状像口袋，通体发光，那光亮如同火焰。它有六只脚、重叠的翅膀，没有面目。它辨识（一说“嗜好”）歌舞，其实就是帝江。刑天与天帝争夺神位，天帝砍下了他的头颅，埋葢在常羊山。刑天便以双乳为目，以肚脐为口，手持干戚翥斧继续起舞。"
    },
    {
      "pid": "V14-P006",
      "volume_title": "卷十四·诺皋记上",
      "narrative_category": "异闻志怪",
      "title": "天翁张坚窃车登天",
      "brief": "渔阳人张坚少不羁，蓄白雀得报天翁杀之未遂，后窃天翁车乘白龙登天，易百官，封白雀为上卿，以刘翁为太山太守主生死籍。",
      "monster_type": "神仙志怪",
      "original_text": "天翁姓张名坚，字刺渴，渔阳人。少不羁，无所拘忌。常张罗得一白雀，爱而养之。梦天刘翁责怒，每欲杀之，白雀辄以报坚，坚设诸方待之，终莫能害。天翁遂下观之，坚盛设宾主，乃窃骑天翁车，乘白龙，振策登天。天公乘馀龙追之，不及。坚既到玄宫，易百官，杜塞北门，封白雀为上卿侯，改白雀之胤不产于下土。刘翁失治，徘徊五岳作灾。坚患之，以刘翁为太山太守，主生死之籍。",
      "themes": [
        {
          "broad_category": "动物",
          "level1_subject": "鸟类",
          "level2_subject": "雀",
          "specific_subject": "雀"
        },
        {
          "broad_category": "动物",
          "level1_subject": "神物",
          "level2_subject": "龙",
          "specific_subject": "龙"
        },
        {
          "broad_category": "建筑寺塔",
          "level1_subject": "寺观",
          "level2_subject": "观",
          "specific_subject": "观"
        },
        {
          "broad_category": "建筑寺塔",
          "level1_subject": "宫殿",
          "level2_subject": "宫",
          "specific_subject": "宫"
        },
        {
          "broad_category": "梦兆占验",
          "level1_subject": "梦",
          "level2_subject": "梦",
          "specific_subject": "梦"
        }
      ],
      "shengui_keywords": [
        "龙"
      ],
      "keyword_count": 1,
      "translation": "天翁姓张名坚，字刺渴，渔阳人。他年少时不守规矩，不受任何拘束。他曾张网捕得一只白雀，十分喜爱便养了起来。梦中天上的刘翁对他大发雷霆，每次想要杀他，白雀总会事先报信给张坚，张坚于是设下各种防备，最终刘翁始终无法加害于他。刘翁于是亲自下界来查看，张坚盛设宴席款待，然后趁机窃骑了刘翁的车驾，乘白龙挥鞭直上九天。天公乘着其余的龙追赶，却没有追上。张坚到达天宫之后，便更换了百官，封闭了北天门，封白雀为上卿侯，更改白雀的后代使其不再降生人间。刘翁失去了治理之权，便徘徊于五岳之间兴灾作祸。张坚对此颇为忧虑，于是任命刘翁为泰山太守，掌管生死簿籍。"
    },
    {
      "pid": "V14-P010",
      "volume_title": "卷十四·诺皋记上",
      "narrative_category": "异闻志怪",
      "title": "灶神名隗状如美女",
      "brief": "灶神名隗，状如美女，又姓张名单字子郭，夫人字卿忌，有六女。常以月晦日上天白人罪状，大者夺纪三百日，小者夺算百日。其属神有天帝娇孙、天帝大夫等。",
      "monster_type": "民俗神灵",
      "original_text": "灶神名隗，状如美女。又姓张名单，字子郭。夫人字卿忌，有六女，皆名察（一作祭）洽。常以月晦日上天白人罪状，大者夺纪，纪三百日，小者夺算，算一百日。故为天帝督使，下为地精。己丑日，日出卯时上天，禺中下行署，此日祭得福。其属神有天帝娇孙、天帝大夫、天帝都尉、天帝长兄、硎上童子、突上紫宫君、太和君、玉池夫人等。一曰灶神名壤子也。",
      "themes": [
        {
          "broad_category": "神怪妖魅",
          "level1_subject": "精",
          "level2_subject": "精",
          "specific_subject": "精"
        },
        {
          "broad_category": "建筑寺塔",
          "level1_subject": "宫殿",
          "level2_subject": "宫",
          "specific_subject": "宫"
        }
      ],
      "shengui_keywords": [
        "精",
        "神",
        "天帝"
      ],
      "keyword_count": 3,
      "translation": "灶神名叫隗，形貌如同美女。又说他姓张名单，字子郭。他的夫人字卿忌，有六个女儿，都名叫察（一作祭）洽。灶神常在每月最后一天上天禪告人的罪状，罪大的减寿一纪（三百日），罪小的减寿一算（一百日）。他本是天帝的督使，在下界则为地精。巳丑日，日出卯时升天，到日中便下到各署办公，在这一天祭祠灶神可得福。他属下的神灵有天帝娇孙、天帝大夫、天帝都尉、天帝长兄、硇上童子、突上紫宫君、太和君、玉池夫人等。一说灶神名叫壤子。"
    },
    {
      "pid": "V14-P014",
      "volume_title": "卷十四·诺皋记上",
      "narrative_category": "异闻志怪",
      "title": "古龟兹国王降伏毒龙",
      "brief": "龟兹国王阿主儿有神异，能降伏毒龙。龙化狮子，王即乘之。龙怒腾空至城北二十里，王叱之，龙惧神力降服，后常乘龙而行。",
      "monster_type": "降妖伏魔",
      "original_text": "古龟兹国王阿主儿者，有神异，力能降伏毒龙。时有贾人买市人金银宝货，至夜中，钱并化为炭。境内数百家皆失金宝。王有男先出家，成阿罗汉果。王问之，罗汉曰：「此龙所为。龙居北山，其头若虎，今在某处眠耳。」王乃易衣持剑默出。至龙所，见龙卧，将欲斩之，因曰：「吾斩寐龙，谁知吾有神力。」遂叱龙，龙惊起，化为狮子，王即乘其上。龙怒，作雷声，腾空至城北二十里。王谓龙曰：「尔不降，当断尔头。」龙惧王神力，乃作人语曰：「勿杀我，我当与王乘，欲有所向，随心即至。」王许之。后常乘龙而行。",
      "themes": [
